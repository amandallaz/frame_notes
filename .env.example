# Copy to .env (not committed). Not used on the server the same way — see below.

# Local Mac (default — omit ENVIRONMENT or use development)
ENVIRONMENT=development

# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ngrok (optional — local dev only; see README)

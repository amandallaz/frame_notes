# Copy to .env (not committed). When set, scans upload to Cloudinary.

# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Or:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ngrok (optional — local dev only; see README)
# NGROK_ORIGIN=https://your-name.ngrok-free.dev

# Production (server .env)
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=generate-a-long-random-string
# ALLOWED_HOSTS=67.205.143.130,your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
# (IP-only HTTP: http://67.205.143.130 — add https:// after SSL)
